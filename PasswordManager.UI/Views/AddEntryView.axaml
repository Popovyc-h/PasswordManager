<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PasswordManager.UI.ViewModels"
             x:DataType="vm:AddEntryViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PasswordManager.UI.Views.AddEntryView">

     <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        
        <!-- Центруємо всю форму на екрані та задаємо оптимальну ширину -->
        <StackPanel Margin="40,30" MaxWidth="460" HorizontalAlignment="Center" Spacing="24">
            
            <!-- Заголовок форми з підзаголовком -->
            <StackPanel Spacing="4">
                <TextBlock Text="Новий запис" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextMain}"/>
                <TextBlock Text="Заповніть дані для безпечного збереження" 
                           FontSize="13" 
                           Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>

            <!-- Основний блок полів введення -->
            <StackPanel Spacing="16">
                
                <TextBox Watermark="Назва сервісу (напр. Google)" Text="{Binding Title}" />
                <TextBox Watermark="Логін / Email" Text="{Binding Login}" />
                <TextBox Watermark="URL адреса (напр. https://google.com)" Text="{Binding Url}" />

                <!-- Рядок пароля: поле + кнопка генерації -->
                <Grid ColumnDefinitions="*, Auto">
                    <!-- RevealPasswordButtonVisible автоматично додає іконку "око" всередину поля -->
                    <TextBox Grid.Column="0" 
                             Watermark="Пароль" 
                             PasswordChar="*" 
                             Text="{Binding Password}" />
                    
                    <Button Grid.Column="1" 
                            Content="Згенерувати" 
                            Command="{Binding GeneratePasswordCommand}"
                            Classes="main" 
                            Margin="12,0,0,0"
                            Padding="16,0"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"/>
                </Grid>

                <!-- Картка налаштувань генератора -->
                <Border Background="{DynamicResource SecondBackground}" 
                        BorderBrush="{DynamicResource BorderColor}" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="20,16">
                    
                    <StackPanel Spacing="14">
                        
                        <TextBlock Text="Налаштування генератора" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" 
                                   Foreground="{DynamicResource TextMain}"/>
                        
                        <!-- Довжина пароля -->
                        <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Довжина символів:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <!-- NumericUpDown набагато акуратніший та зручніший у використанні, ніж Slider -->
                            <NumericUpDown Grid.Column="1" Minimum="8" Maximum="64" Value="{Binding Length}" FormatString="0" Width="110" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <!-- Лінія-розділювач для візуального порядку -->
                        <Separator Background="{DynamicResource BorderColor}" Height="1" Margin="0,4"/>
                        
                        <!-- Опції у два стовпчики (UniformGrid економить купу вертикального простору) -->
                        <UniformGrid Columns="2" Rows="2">
                            <CheckBox Content="Великі літери (A-Z)" IsChecked="{Binding UseUppercase}" Margin="0,4"/>
                            <CheckBox Content="Малі літери (a-z)" IsChecked="{Binding UseLowercase}" Margin="0,4"/>
                            <CheckBox Content="Цифри (0-9)" IsChecked="{Binding UseDigits}" Margin="0,4"/>
                            <CheckBox Content="Спеціальні (!@#)" IsChecked="{Binding UseSpecial}" Margin="0,4"/>
                        </UniformGrid>
                        
                    </StackPanel>
                </Border>

                <!-- Нотатки -->
                <TextBox Watermark="Додаткові нотатки..." 
                         Text="{Binding Notes}" 
                         AcceptsReturn="True" 
                         Height="100" 
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Padding="10,12"/>
           
            </StackPanel>

            <!-- Нижні кнопки дій -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0" 
                        Content="Скасувати" 
                        Background="Transparent" 
                        BorderBrush="{DynamicResource BorderColor}" 
                        BorderThickness="1"
                        Height="42"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
               
                <Button Grid.Column="1" 
                        Content="Зберегти запис" 
                        Command="{Binding SaveCommand}" 
                        Classes="main" 
                        Height="42"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>