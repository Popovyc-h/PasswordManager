<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PasswordManager.UI.ViewModels"
             x:DataType="vm:AddEntryViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PasswordManager.UI.Views.AddEntryView"
             Background="{DynamicResource MainBackground}">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverColor}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            
            <Border Background="{DynamicResource SecondBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="16"
                    BoxShadow="0 4 18 0 #05000000"
                    Width="480"
                    Padding="32,28">
                
                <StackPanel Spacing="24">
                    
                    <StackPanel Spacing="6">
                        <TextBlock Text="Новий запис" 
                                   FontSize="24" 
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource TextMain}"/>
                        <TextBlock Text="Заповніть дані для безпечного збереження" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>

                    <Separator Height="1" Background="{DynamicResource BorderColor}" Margin="0,-4,0,4"/>

                    <StackPanel Spacing="16">
                        
                        <StackPanel Spacing="6">
                            <TextBlock Text="Назва сервісу" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Watermark="Наприклад, Google, GitHub..." Text="{Binding Title}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Логін або Email" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Watermark="username @ email.com" Text="{Binding Login}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Веб-сайт" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Watermark="https://example.com" Text="{Binding Url}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Пароль" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" 
                                         Watermark="Введіть пароль" 
                                         PasswordChar="*" 
                                         Theme="{StaticResource FluentTextBox}"
                                         Text="{Binding Password}" />
                                
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Нотатки" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Watermark="Додаткова інформація (PIN-коди, секретні питання)..." 
                                     Text="{Binding Notes}" 
                                     AcceptsReturn="True" 
                                     Height="90" 
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>
                   
                    </StackPanel>

                    <Grid ColumnSpacing="12" Margin="0,8,0,0">

                       
                        <Button Grid.Column="1" 
                                Content="Зберегти" 
                                Command="{Binding SaveCommand}" 
                                Classes="main" 
                                Height="40"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>