<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PasswordManager.UI.Views.MainDashboardView">

<Grid ColumnDefinitions="260, *">
    <Border Grid.Column="0" Background="{DynamicResource SecondBackground}" BorderThickness="0,0,1,0" BorderBrush="#2A2A2A">

    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto, *" Margin="20">
        

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="12" Padding="20">
        </Border>
    </Grid>
</Grid>

</UserControl>
