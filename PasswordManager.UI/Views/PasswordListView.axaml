<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
             xmlns:vm="using:PasswordManager.UI.ViewModels"
             x:DataType="vm:PasswordListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="PasswordManager.UI.Views.PasswordListView">
 
    <Grid Margin="32" RowDefinitions="Auto, *">
        
        <TextBlock Grid.Row="0"
                   Text="Мої паролі" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="{DynamicResource TextMain}"
                   Margin="0,0,0,24"/>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding PasswordEntries}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0">
           
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PasswordEntryItemViewModel">
                    
                    <Border Background="{DynamicResource SecondBackground}" 
                            CornerRadius="12" 
                            Padding="20,16" 
                            Margin="0,0,0,12"
                            BoxShadow="0 4 12 0 #08000000">
                        
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto, Auto, Auto, Auto" VerticalAlignment="Center">
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Spacing="6" Margin="0,0,16,0">
                                
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Entry.Title}" 
                                               FontSize="16" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextMain}"/>
                                    
                                    <Border Background="#2A2D34" 
                                            BorderBrush="#3F424A" 
                                            BorderThickness="1" 
                                            CornerRadius="6" 
                                            Padding="8,2"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding Entry.Category, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding Entry.Category.Name}" 
                                                   Foreground="#98C379" 
                                                   FontSize="11" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <Grid ColumnDefinitions="Auto, Auto, *">
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Entry.Login}" 
                                               FontSize="13" 
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="1" 
                                               Text="•" 
                                               Margin="8,0"
                                               Foreground="{DynamicResource TextSecondary}" 
                                               IsVisible="{Binding Entry.Url, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               VerticalAlignment="Center"/>
                                    
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding Entry.Url}" 
                                               FontSize="13"
                                               Foreground="#5865F2"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center" 
                                        Margin="24,0">
                                
                                <TextBlock Text="••••••••" 
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"
                                           IsVisible="{Binding !IsRevealed}"/>
                                
                                <TextBlock Text="{Binding DecryptedPassword}" 
                                           FontSize="15" 
                                           FontFamily="Courier New, monospace"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMain}"
                                           IsVisible="{Binding IsRevealed}"/>
                            </StackPanel>
                            
                            <Button Grid.Row="0" Grid.Column="2" 
                                    Command="{Binding ToggleRevealCommand}"
                                    CornerRadius="20"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <svg:Svg Path="avares://PasswordManager.UI/Assets/eye.svg" Width="20" Height="20"/>
                            </Button>
                   
                            <Button Grid.Row="0" Grid.Column="3" 
                                    Content="Видалити" 
                                    Command="{Binding $parent[ListBox].((vm:PasswordListViewModel)DataContext).DeleteEntryCommand}" 
                                    CommandParameter="{Binding}"
                                    Background="#DA373C"
                                    Foreground="White"
                                    CornerRadius="6"
                                    Padding="12,6"
                                    Margin="4,0"/>

                            <Button Grid.Row="0" Grid.Column="4"
                                    Command="{Binding EditEntryCommand}"
                                    Content="Редагувати"
                                    Foreground="{DynamicResource TextMain}"
                                    CornerRadius="20"
                                    Background="Transparent"
                                    BorderThickness="0"/>

                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                                    Margin="0,12,0,0" 
                                    Padding="12,10"
                                    Background="#1E1F22" 
                                    CornerRadius="6"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding Entry.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Нотатки:" 
                                               Foreground="{DynamicResource TextSecondary}" 
                                               FontWeight="Medium" 
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding Entry.Notes}" 
                                               Foreground="{DynamicResource TextMain}" 
                                               FontSize="12" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>
                
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>