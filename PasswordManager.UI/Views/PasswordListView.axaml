<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
             xmlns:vm="using:PasswordManager.UI.ViewModels"
             x:DataType="vm:PasswordListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="PasswordManager.UI.Views.PasswordListView">
 
    <Grid Margin="32" RowDefinitions="Auto, *">
        
        <TextBlock Grid.Row="0"
                   Text="Мої паролі" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="{DynamicResource TextMain}"
                   Margin="0,0,0,24"/>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding PasswordEntries}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0">
           
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PasswordEntryItemViewModel">
                    
                    <Border Background="{DynamicResource SecondBackground}" 
                            CornerRadius="12" 
                            Padding="20,16" 
                            Margin="0,0,0,12"
                            BoxShadow="0 4 12 0 #08000000">
                        
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" VerticalAlignment="Center">
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Entry.Title}" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMain}"/>

                                <TextBlock Text="{Binding Entry.Login}" 
                                           FontSize="14" 
                                           Foreground="{DynamicResource TextSecondary}"/>

                                <TextBlock Text="{Binding Entry.Url}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center" 
                                        Margin="24,0">
                                
                                <TextBlock Text="••••••••" 
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"
                                           IsVisible="{Binding !IsRevealed}"/>
                                
                                <TextBlock Text="{Binding DecryptedPassword}" 
                                           FontSize="15" 
                                           FontFamily="Courier New, monospace"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextMain}"
                                           IsVisible="{Binding IsRevealed}"/>
                            </StackPanel>
                            
                            <Button Grid.Column="2" 
                                    Command="{Binding ToggleRevealCommand}"
                                    CornerRadius="20"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <svg:Svg Path="avares://PasswordManager.UI/Assets/eye.svg" Width="20" Height="20"/>
                            </Button>
                   
                            <Button Grid.Column="3" 
                                    Content="Видалити" 
                                    Command="{Binding $parent[ListBox].((vm:PasswordListViewModel)DataContext).DeleteEntryCommand}" 
                                    CommandParameter="{Binding}"/>

                        </Grid>
                    </Border>
                
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>